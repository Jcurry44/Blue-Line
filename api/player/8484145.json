d": 3455230, "aavHigh": 4074713, "term": 2, "capPctMid": 3.3, "n": 14}, "longTerm": {"aavLow": 6850601, "aavMid": 7737862, "aavHigh": 8923805, "term": 7, "capPctMid": 7.4, "n": 14}, "matched": null, "actualAav": null, "actualTerm": null, "inBand": null, "err": null, "actualDate": null}, "explain": {"scorecard": {"value": {"receipts": [{"label": "Even strength (5v5)", "value": "+2.67 WAR", "tone": "pos"}, {"label": "Special teams (PP + PK)", "value": "+0.27 WAR", "tone": "pos"}, {"label": "Penalty discipline (vs position)", "value": "-0.04 WAR", "tone": "neutral"}, {"label": "Faceoffs", "value": "-0.03 WAR", "tone": "neutral"}, {"label": "Total, last 3 seasons", "value": "+1.45 WAR", "tone": "pos", "strong": true}], "summary": "His total on-ice value, converted to WINS (WAR). It adds up everything he does \u2014 even-strength play, the power play and penalty kill, his penalty discipline RELATIVE TO HIS POSITION (defensemen structurally take more than they draw, so only the differential vs other D counts), and faceoffs \u2014 and the grade ranks that total against other players at his position over the last three seasons.", "method": "Total WAR sums these four, each priced in wins. The grade is this player's percentile vs same-position peers over the 3-season window."}, "overall": {"receipts": [{"label": "5v5 xG impact (RAPM)", "value": "+0.26 xG/60", "tone": "pos", "strong": true}, {"label": "\u2014 offense", "value": "+0.13 xG/60", "tone": "pos"}, {"label": "\u2014 defense", "value": "+0.14 xG/60", "tone": "pos"}, {"label": "5v5 sample", "value": "2,529 min", "tone": "neutral"}, {"label": "On-ice xG share", "value": "54.4%", "tone": "neutral"}, {"label": "Relative to team (on \u2212 off ice)", "value": "+4.7%", "tone": "pos"}], "summary": "His two-way impact at 5-on-5: do his team's scoring chances go UP, and the other team's go DOWN, when he's on the ice? We isolate his effect from his linemates, the competition, and where his shifts start \u2014 so it's his finger