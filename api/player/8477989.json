 creates off the rush \u2014 0.10 per 60 minutes of ice time over his last 3 seasons, ranked against other forwards."}}}, "projection": {"available": true, "asOfSeason": 20252026, "baseWar": 0.06, "years": [{"horizon": 1, "seasonId": 20262027, "age": 31.0, "projWar": 0.02, "lo": -0.57, "hi": 0.61}, {"horizon": 2, "seasonId": 20272028, "age": 32.0, "projWar": -0.04, "lo": -0.65, "hi": 0.57}, {"horizon": 3, "seasonId": 20282029, "age": 33.0, "projWar": -0.09, "lo": -0.73, "hi": 0.55}, {"horizon": 4, "seasonId": 20292030, "age": 34.0, "projWar": -0.15, "lo": -0.81, "hi": 0.51}, {"horizon": 5, "seasonId": 20302031, "age": 35.0, "projWar": -0.22, "lo": -0.89, "hi": 0.45}]}, "clause": {"hasNmc": false, "hasNtc": true, "noTradeListSize": 20, "label": "Modified NTC (20-team)", "terms": "M-NTC", "details": "No-Trade Clause through the 2027-28 league year; converts to a Modified No-Trade Clause with a 20-team no-trade list for 2028-29 and a 5-team no-trade list for 2029-30."}, "trajectory": null, "scorecard": {"offense": 23, "defense": 40, "overall": 28, "peers": 776, "window": "multi-year RAPM (recent 3 seasons)", "recent": {"offense": 30, "defense": 15, "overall": 15, "season": 20252026, "peers": 673}, "value": 17, "valueGroup": "F", "valueTrend": [{"season": 20222023, "pctl": 3}, {"season": 20232024, "pctl": 22}, {"season": 20242025, "pctl": 38}, {"season": 20252026, "pctl": 8}], "finishing": 24, "ppOffense": 94, "pkDefense": 40}, "skills": {"percentiles": {"hits60": 17.1, "blocks60": 76.9, "takeaways60": 30.6, "giveaways60": 26.2, "primary_assists60": 75.0, "rush_xg60": 61.1}, "window": "recent 3 seasons, TOI-weighted, vs position peers", "note": "hits/takeaways/giveaways are RTSS-tracked (arena scorer bias, not adjusted); giveaways shown as puck security (100 = fewest). All-situations TOI denominates rates.", "edge": {"season": 20252026, "maxSpeedMph": 22.3463, "maxSpeedPct": 56.0, "bursts22": 3, "bursts22Pct": 66.0, "bursts2022Pct": 96.2, "bursts1820Pct": 97.7, "distPer